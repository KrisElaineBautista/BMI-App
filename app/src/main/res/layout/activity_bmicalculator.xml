<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#71BAAF"
    android:textAlignment="center"
    tools:context=".BMIcalculator">
    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="109dp"
        android:layout_height="84dp"
        app:layout_constraintBottom_toTopOf="@+id/txtnameresult"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.8"
        app:srcCompat="@drawable/resultsicon" />
    <TextView
        android:id="@+id/txtnameresult"
        android:layout_width="187dp"
        android:layout_height="42dp"
        android:layout_marginBottom="8dp"
        android:autoText="false"
        android:background="@drawable/rounded_corner_background"
        android:backgroundTint="#DADADA"
        android:text="RESULT"
        android:textAlignment="inherit"
        android:textColor="@color/black"
        android:textSize="40dp"
        android:textStyle="bold"
        app:autoSizeTextType="uniform"
        app:layout_constraintBottom_toTopOf="@+id/linearLayout5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <LinearLayout
        android:id="@+id/linearLayout5"
        android:layout_width="358dp"
        android:layout_height="71dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/rounded_corner_background"
        android:backgroundTint="#00B0FF"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/linearLayout6"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:ignore="MissingConstraints">
        <TextView
            android:id="@+id/txtFullname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="FULLNAME"
            android:textAlignment="inherit"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/linearLayout6"
        android:layout_width="295dp"
        android:layout_height="343dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/rounded_corner_background"
        android:backgroundTint="#2979FF"
        android:orientation="vertical"
        android:textAlignment="center"
        app:layout_constraintBottom_toTopOf="@+id/txtsuggest"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        tools:ignore="MissingConstraints">
        <TextView
            android:id="@+id/txtBMI"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"
            android:text="BMI "
            android:textAlignment="center"
            android:textColor="#FFFEFE"
            android:textSize="48sp" />
        <TextView
            android:id="@+id/txtresult"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:text="NUM"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="60sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/txtstatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STATUS"
            android:textAlignment="center"
            android:textColor="#FBFBFB"
            android:textSize="25dp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/txtrange"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="40dp"
            android:text="RANGE"
            android:textAlignment="inherit"
            android:textColor="#F4F4F4"
            android:textSize="20dp" />
    </LinearLayout>
    <TextView
        android:id="@+id/txtsuggest"
        android:layout_width="329dp"
        android:layout_height="96dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/rounded_corner_background"
        android:backgroundTint="#DADADA"
        android:scrollbarAlwaysDrawVerticalTrack="true"
        android:scrollbars="vertical"
        android:textAlignment="center"
        android:textStyle="italic"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.493"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>